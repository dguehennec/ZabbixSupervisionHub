{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "__APP_VERSION__",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "browser_specific_settings": {
    "gecko": {
      "id": "zabbix_supervision_hub@davidguehennec.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["authenticationInfo"],
        "optional": []
      }
    }
  },
  "action": {
    "default_icon": {
      "16": "skin/images/zabbix_hub_16.png",
      "32": "skin/images/zabbix_hub_32.png",
      "48": "skin/images/zabbix_hub_48.png",
      "128": "skin/images/zabbix_hub_128.png"
    },
    "default_popup": "src/popup/index.html",
    "default_title": "__MSG_extName__"
  },
  "icons": {
    "16": "skin/images/zabbix_hub_16.png",
    "32": "skin/images/zabbix_hub_32.png",
    "48": "skin/images/zabbix_hub_48.png",
    "128": "skin/images/zabbix_hub_128.png"
  },
  "permissions": ["notifications", "storage", "alarms"],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; object-src 'none'; base-uri 'none'; connect-src 'self' https: http:"
  },
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "scripts": ["src/background/worker.ts"],
    "type": "module"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  }
}
